VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Firebase Auth opcional para UX simples estilo "Continuar com Google".
# Configure em Firebase Console > Authentication > Sign-in method > Google.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=

# Google Identity Services / People API / Calendar API
# Use the public OAuth Client ID for a Web application.
# Authorized JavaScript origins:
# - http://127.0.0.1:5173
# - https://leninn-marinho-rodrigues.github.io
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CONTACTS_SCOPE=https://www.googleapis.com/auth/contacts.readonly
VITE_GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar.readonly

# Sign in with Apple for Web
# Use the Apple Service ID and the exact return URL configured in Apple Developer.
# Do not place Apple client secrets in Vite/front-end variables.
VITE_APPLE_SERVICE_ID=
VITE_APPLE_REDIRECT_URI=
